rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // User profile directory. Any signed-in user can read profiles so
    // the "add friend by email" lookup works. Each user can only write
    // their own profile doc. If `username` is changing, enforce a 24h
    // cooldown via `usernameUpdatedAt`.
    match /users/{uid} {
      function usernameUnchanged() {
        return resource == null
          ? !('username' in request.resource.data)
          : request.resource.data.get('username', null) == resource.data.get('username', null);
      }
      function cooldownPassed() {
        return resource == null
          || resource.data.get('usernameUpdatedAt', null) == null
          || request.time > resource.data.usernameUpdatedAt + duration.value(24, 'h');
      }

      allow read: if signedIn();
      allow create: if isSelf(uid)
        && request.resource.data.uid == uid;
      allow update: if isSelf(uid)
        && request.resource.data.uid == uid
        && (usernameUnchanged() || cooldownPassed());
      allow delete: if false;
    }

    // Username directory: doc id is the lowercased username, value is
    // the owning uid. Acts as a uniqueness index. A user can only
    // create/delete entries pointing at their own uid.
    match /usernames/{username} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // Friendship docs are keyed by sorted-uid pair, e.g. "abc_xyz".
    // Both participants can read; either can create a pending request
    // they originate; either can update status to accepted; either can
    // delete to remove/decline/cancel.
    match /friendships/{pairId} {
      function inPair() {
        return signedIn() && request.auth.uid in resource.data.uids;
      }
      function inNewPair() {
        return signedIn() && request.auth.uid in request.resource.data.uids;
      }

      allow read: if signedIn()
        && (resource == null || request.auth.uid in resource.data.uids);
      allow create: if inNewPair()
        && request.resource.data.requester == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.uids.size() == 2;
      allow update: if inPair()
        && request.resource.data.uids == resource.data.uids
        && request.resource.data.requester == resource.data.requester;
      allow delete: if inPair();
    }

    // Challenges link two friends to a hosted room. Participants can
    // read; the sender creates; either side can update status (accept,
    // decline, cancel) or delete to clean up.
    match /challenges/{challengeId} {
      function isParticipant() {
        return signedIn() && request.auth.uid in resource.data.participants;
      }
      function isNewParticipant() {
        return signedIn() && request.auth.uid in request.resource.data.participants;
      }

      allow read: if signedIn()
        && (resource == null || request.auth.uid in resource.data.participants);
      allow create: if isNewParticipant()
        && request.resource.data.from == request.auth.uid
        && request.resource.data.participants.size() == 2
        && request.resource.data.status == 'pending';
      allow update: if isParticipant()
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.from == resource.data.from
        && request.resource.data.to == resource.data.to;
      allow delete: if isParticipant();
    }

    // Game rooms are accessed by short room code. Signed-in users
    // (including anonymous guests) can read/write so host + joiner can
    // sync state. Rooms self-expire client-side after 4 hours.
    match /games/{roomCode} {
      allow read, write: if signedIn();
    }
  }
}
